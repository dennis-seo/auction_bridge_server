# ===== App =====
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
USE_MOCK=true

# ===== Database (Supabase / PostgreSQL with PostGIS) =====
# Supabase Connection String 형식 (Pooler 권장):
# postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/auctionbridge

# ===== JWT =====
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MIN=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14

# ===== Kakao OAuth (Local API와 동일 키 공유) =====
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/kakao/callback
KAKAO_CLIENT_SECRET=

# ===== 공공데이터포털 (온비드) =====
ONBID_SERVICE_KEY=

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== Daily ingest 파라미터 (Cloud Scheduler가 호출) =====
SCHEDULER_PAGES_PER_ASSET=20
SCHEDULER_NUM_OF_ROWS=200
SCHEDULER_BID_RESULT_LIMIT=200
SCHEDULER_IMAGE_LIMIT=0

# ===== Cloud Scheduler → Cloud Run OIDC 인증 =====
# 배포 후 채워질 값. Cloud Scheduler가 사용하는 SA 이메일과 Cloud Run URL.
CRON_SERVICE_ACCOUNT_EMAIL=
CRON_AUDIENCE=
