# 프로덕션(Cloud Run)용 환경변수 템플릿
# 이 파일을 복사해서 .env.production 으로 만들고 실제 값 채우기:
#   cp .env.production.example .env.production
#
# .env.production 은 .gitignore 에 있어 커밋되지 않음.
# deploy.ps1 이 이 파일을 읽어 Cloud Run에 --env-vars-file로 주입.

# ===== App =====
APP_ENV=prod
APP_DEBUG=false
USE_MOCK=false

# ===== Database (Supabase Pooler) =====
# 비밀번호에 특수문자(@, :, #, /, ?, $ 등)가 있으면 반드시 percent-encode 해야 합니다.
# 예: $ → %24, @ → %40, : → %3A, / → %2F
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ===== JWT =====
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MIN=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14

# ===== Kakao OAuth =====
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=
KAKAO_CLIENT_SECRET=

# ===== 공공데이터포털 (온비드) =====
ONBID_SERVICE_KEY=

# ===== CORS =====
# 프론트 도메인이 정해지기 전이면 localhost만 둬도 됩니다 (모바일/네이티브 앱은 CORS 무관).
# 콤마로 여러 origin 구분. 와일드카드(*)는 자격증명 함께 사용 시 거부됨.
CORS_ORIGINS=http://localhost:3000

# ===== Daily ingest 파라미터 =====
SCHEDULER_PAGES_PER_ASSET=20
SCHEDULER_NUM_OF_ROWS=200
SCHEDULER_BID_RESULT_LIMIT=200
SCHEDULER_IMAGE_LIMIT=0

# ===== Cloud Scheduler OIDC =====
# CRON_SERVICE_ACCOUNT_EMAIL / CRON_AUDIENCE 는 deploy 스크립트(로컬·CI)가 자동 주입합니다.
# 이 파일에 빈 값으로 두면 자동 주입 로직이 무력화되니 절대 추가하지 마세요.
