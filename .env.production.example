# 프로덕션(Cloud Run)용 환경변수 템플릿
# 이 파일을 복사해서 .env.production 으로 만들고 실제 값 채우기:
#   cp .env.production.example .env.production
#
# .env.production 은 .gitignore 에 있어 커밋되지 않음.
# deploy.ps1 이 이 파일을 읽어 Cloud Run에 --env-vars-file로 주입.

# ===== App =====
APP_ENV=prod
APP_DEBUG=false
USE_MOCK=false

# ===== Database (Supabase Pooler) =====
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ===== JWT =====
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MIN=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14

# ===== Kakao OAuth =====
KAKAO_REST_API_KEY=
KAKAO_REDIRECT_URI=
KAKAO_CLIENT_SECRET=

# ===== 공공데이터포털 (온비드) =====
ONBID_SERVICE_KEY=

# ===== CORS (배포 후 실제 프론트 도메인) =====
CORS_ORIGINS=https://your-frontend-domain.com

# ===== Daily ingest 파라미터 =====
SCHEDULER_PAGES_PER_ASSET=20
SCHEDULER_NUM_OF_ROWS=200
SCHEDULER_BID_RESULT_LIMIT=200
SCHEDULER_IMAGE_LIMIT=0

# ===== Cloud Scheduler OIDC (deploy.ps1 이 자동 채움 — 비워둬도 됨) =====
CRON_SERVICE_ACCOUNT_EMAIL=
CRON_AUDIENCE=
